---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  currentPage?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  currentPage = 'home',
  ogImage = '/leo-monteiro.jpg',
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl = 'https://leomonteiro.pt';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "@id": `${siteUrl}/#clinic`,
  "name": "Leo Monteiro, Clínica da Dor Taguspark",
  "url": siteUrl,
  "telephone": "+351916345523",
  "email": "leo@leomonteiro.pt",
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Taguspark, Núcleo Central, 3º Piso, Sala 340",
    "addressLocality": "Oeiras",
    "postalCode": "2740-122",
    "addressRegion": "Oeiras",
    "addressCountry": "PT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 38.7370,
    "longitude": -9.3045
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday"],
    "opens": "10:00",
    "closes": "17:00"
  }],
  "medicalSpecialty": ["Acupuncture", "PainManagement", "Chiropractic"],
  "sameAs": [
    "https://www.linkedin.com/in/leomonteiropt",
    "https://www.instagram.com/leomonteiro.pt/",
    "https://www.facebook.com/LeoMonteiro.pt"
  ]
};
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO primário -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Leo Monteiro, Acupuntura e Terapia Manual" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Técnico -->
    <meta name="author" content="Leonardo Monteiro" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1E4A5C" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Schema.org MedicalClinic -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar para o conteúdo</a>
    <Header currentPage={currentPage} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp flutuante -->
    <a
      href="https://wa.me/351916345523?text=Ol%C3%A1%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o"
      class="whatsapp-float"
      aria-label="Contactar por WhatsApp"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>
