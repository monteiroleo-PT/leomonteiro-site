---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contactos, Taguspark, Oeiras | Leo Monteiro"
  description="Contactos do consultório Leo Monteiro no Taguspark, Oeiras. WhatsApp, email, morada e mapa. Marcação rápida pelo WhatsApp."
  currentPage="contactos"
>

  <!-- HERO -->
  <section class="contact-hero">
    <div class="container">
      <p class="eyebrow center">Contactos</p>
      <h1>Estamos <em class="accent">no Taguspark.</em></h1>
      <p class="lead center">
        Núcleo Central, 3º piso, Sala 340, Oeiras.
        A 10 minutos a pé de qualquer ponto do parque.
      </p>
    </div>
  </section>

  <!-- MAIN -->
  <section class="contact-main">
    <div class="container">
      <div class="contact-grid">
        <div class="info-card">
          <div class="info-block">
            <p class="info-label">WhatsApp</p>
            <p class="info-value">
              <a href="https://wa.me/351916345523" target="_blank" rel="noopener">+351 916 345 523</a>
            </p>
            <p class="info-sub">Marcações rápidas, dúvidas e situações urgentes</p>
          </div>
          <div class="info-block">
            <p class="info-label">Email</p>
            <p class="info-value">
              <a href="mailto:leo@leomonteiro.pt">leo@leomonteiro.pt</a>
            </p>
            <p class="info-sub">Resposta em 24 horas úteis</p>
          </div>
          <div class="info-block">
            <p class="info-label">Morada</p>
            <p class="info-value">Taguspark, Sala 340</p>
            <p class="info-sub">
              Edifício Núcleo Central, 3º Piso<br />
              2740-122 Oeiras
            </p>
          </div>
          <div class="info-block">
            <p class="info-label">Horário</p>
            <p class="info-value">Seg a Qui</p>
            <p class="info-sub">10h às 17h · Outros horários sob marcação</p>
          </div>
          <div class="info-cta">
            <a
              href="https://wa.me/351916345523?text=Ol%C3%A1%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o"
              class="btn btn-primary"
              target="_blank" rel="noopener noreferrer"
            >
              Marcar pelo WhatsApp
              <span class="btn-arrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        </div>

        <div>
          <div class="map-wrapper">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3113.8!2d-9.3045!3d38.7370!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDQ0JzEzLjIiTiA5wrAxOCcxNi4yIlc!5e0!3m2!1spt!2spt!4v1"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Localização do consultório Leo Monteiro no Taguspark"
            ></iframe>
          </div>
          <div class="map-cta">
            <a
              href="https://maps.app.goo.gl/a18hJq334fjEPqxh7"
              target="_blank" rel="noopener noreferrer"
              class="btn-ghost"
            >
              Abrir no Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIRECTIONS -->
  <section class="directions">
    <div class="container">
      <p class="eyebrow">Como chegar</p>
      <h2>Fácil de encontrar, <em class="accent">fácil de chegar.</em></h2>
      <div class="directions-grid">
        <div class="direction-item">
          <p class="direction-icon">A pé</p>
          <h3>Desde o Taguspark</h3>
          <p>
            10 minutos a pé desde qualquer empresa do parque.
            Entrada pelo Núcleo Central, junto à receção há dois elevadores,
            subir ao 3.º piso, Sala 340.
          </p>
        </div>
        <div class="direction-item">
          <p class="direction-icon">De carro</p>
          <h3>Desde Lisboa ou Cascais</h3>
          <p>
            A5/IC19 saída Taguspark/Porto Salvo.
            Parque de estacionamento gratuito no exterior do parque.
          </p>
        </div>
        <div class="direction-item">
          <p class="direction-icon">Transporte</p>
          <h3>Autocarro</h3>
          <p>
            Linha Cascais-Oeiras com paragem no Taguspark.
            Comboio Linha de Cascais, estação Oeiras, com autocarros frequentes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOURS -->
  <section class="hours-section">
    <div class="container">
      <div class="hours-grid">
        <div>
          <p class="eyebrow">Horário</p>
          <h2>Consultas de <em class="accent">segunda a quinta.</em></h2>
          <p style="color: var(--gray); margin-top: 1rem; font-size: 1.05rem; line-height: 1.7;">
            Atendimento na hora de almoço e pós-laboral disponível mediante marcação prévia.
            Urgências para casos agudos, sempre que a agenda permite.
          </p>
        </div>
        <div class="hours-table">
          <div class="hours-row">
            <span class="hours-day">Segunda-feira</span>
            <span class="hours-time">10h00 às 17h00</span>
          </div>
          <div class="hours-row">
            <span class="hours-day">Terça-feira</span>
            <span class="hours-time">10h00 às 17h00</span>
          </div>
          <div class="hours-row">
            <span class="hours-day">Quarta-feira</span>
            <span class="hours-time">10h00 às 17h00</span>
          </div>
          <div class="hours-row">
            <span class="hours-day">Quinta-feira</span>
            <span class="hours-time">10h00 às 17h00</span>
          </div>
          <div class="hours-row closed">
            <span class="hours-day">Sexta-feira</span>
            <span class="hours-time">Fechado</span>
          </div>
          <div class="hours-row closed">
            <span class="hours-day">Fim de semana</span>
            <span class="hours-time">Fechado</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA DARK -->
  <section class="contact-cta">
    <div class="container">
      <p class="eyebrow eyebrow-light center">Marcar consulta</p>
      <h2>Pronto para <em class="accent-light">começar?</em></h2>
      <p>
        Marcação em 30 segundos pelo WhatsApp.
        Resposta rápida, mesmo-dia em situações urgentes.
      </p>
      <div class="actions" style="justify-content: center;">
        <a
          href="https://wa.me/351916345523?text=Ol%C3%A1%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o"
          class="btn btn-primary"
          target="_blank" rel="noopener noreferrer"
        >
          Marcar pelo WhatsApp
          <span class="btn-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="/marcar-consulta" class="btn-ghost" style="color: rgba(250,247,242,0.8) !important; border-color: rgba(250,247,242,0.4);">
          Agenda online
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-hero { padding: clamp(3rem, 6vw, 5rem) 0 clamp(2rem, 4vw, 3rem); text-align: center; }
  .contact-hero h1 { font-size: clamp(2.5rem, 4.5vw, 3.75rem); margin-bottom: 1rem; }
  .lead.center { max-width: 36rem; margin: 0 auto; }

  .contact-main { padding-bottom: clamp(4rem, 8vw, 6rem); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }

  .info-card { background: var(--cream-warm); padding: 2.5rem; border-radius: 4px; }
  .info-block { padding: 1.5rem 0; border-bottom: 1px solid var(--border-dark); }
  .info-block:first-of-type { padding-top: 0; }
  .info-block:last-of-type { border-bottom: none; padding-bottom: 0; }
  .info-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--teal); font-weight: 600; margin-bottom: 0.65rem; }
  .info-value { font-size: 1.5rem; color: var(--ink-deep); font-weight: 500; line-height: 1.3; margin-bottom: 0.25rem; }
  .info-value a { color: var(--ink-deep); border-bottom: 1px solid transparent; transition: border-color var(--t-fast); }
  .info-value a:hover { color: var(--teal); border-bottom-color: var(--teal); }
  .info-sub { font-size: 0.92rem; color: var(--gray); line-height: 1.5; margin-bottom: 0; }
  .info-cta { margin-top: 1.5rem; }
  .info-cta .btn { width: 100%; justify-content: center; }

  .map-wrapper { aspect-ratio: 4/3; border-radius: 4px; overflow: hidden; position: relative; }
  .map-wrapper iframe { width: 100%; height: 100%; border: none; }
  .map-cta { margin-top: 1rem; }

  .directions { background: var(--cream); }
  .directions h2 { font-size: clamp(1.85rem, 3.5vw, 2.5rem); margin-bottom: 0.5rem; }
  .directions-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; margin-top: 3rem; }
  .direction-item { padding-top: 1.5rem; border-top: 1px solid var(--border-dark); }
  .direction-icon { font-style: italic; font-size: 1.1rem; color: var(--teal); margin-bottom: 0.5rem; font-weight: 500; }
  .direction-item h3 { font-size: 1.35rem; margin-bottom: 0.75rem; }
  .direction-item p { color: var(--gray); font-size: 0.97rem; line-height: 1.65; margin-bottom: 0; }

  .hours-section { background: var(--cream-warm); }
  .hours-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .hours-table { width: 100%; }
  .hours-row { display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--border-dark); align-items: center; }
  .hours-row:last-child { border-bottom: none; }
  .hours-day { font-size: 1.1rem; color: var(--ink-deep); font-weight: 500; }
  .hours-time { color: var(--gray); font-size: 0.95rem; }
  .hours-row.closed .hours-day, .hours-row.closed .hours-time { color: var(--gray-light); }

  .contact-cta { background: var(--ink-deep); color: var(--cream); text-align: center; padding: clamp(4rem, 8vw, 6rem) 0; }
  .contact-cta h2 { color: var(--cream); max-width: 32rem; margin: 0 auto 1.5rem; }
  .contact-cta p { font-size: 1.1rem; color: rgba(250,247,242,0.8); max-width: 32rem; margin: 0 auto 2rem; }
  .eyebrow-light { color: var(--teal-light); background: rgba(91,168,184,0.15); border-color: rgba(91,168,184,0.3); }
  .accent-light { font-style: italic; color: var(--teal-light); font-weight: 400; }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .directions-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hours-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
